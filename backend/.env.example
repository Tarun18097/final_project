# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://127.0.0.1:27017/api_security
# MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/api_security

# ── JWT ───────────────────────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRY=24h

# ── Admin user (created on first run if no admin exists) ──────────────────────
ADMIN_PASSWORD=admin123

# ── Frontend URL (for CORS + Socket.IO) ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Detection thresholds ──────────────────────────────────────────────────────
RATE_LIMIT_THRESHOLD=30
BRUTE_FORCE_THRESHOLD=5
